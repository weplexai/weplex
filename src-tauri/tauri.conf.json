    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/weplex-mcp"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Evgeniy Solomein (L7JBY5W444)"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://dl.weplex.ai/version.json",
        "https://dl.weplex.xyz/version.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUyNkE1NDlGMDcyQ0U5MjEKUldRaDZTd0huMVJxNHF5eFVmMWdIVXROQ3BCTzJWV2ZTWU1XQmNmUDZDb1MxNFVwSERYNXFTLy8K"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Weplex",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": [10, 10, 15, 255]
      }
    ]
  }
}
