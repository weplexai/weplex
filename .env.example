# Apple signing (macOS only) — put your Developer ID password in .env, not here.
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=

# PostHog (optional — analytics and feature flags).
# If VITE_POSTHOG_KEY is not set, analytics is a no-op and feature flags
# return their fallbacks (off for alpha).
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
